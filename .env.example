# ============================================================
# HomeAgent — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# LLM Providers
# ------------------------------------------------------------

# Anthropic Claude (primary model)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (fallback model + embeddings)
OPENAI_API_KEY=sk-...

# Per-slot API keys — optional, takes precedence over the global keys above.
# Use these to explicitly bind a model slot to a specific provider/key.
# If unset, the global key matching the model name prefix is used as fallback.
# MODEL_PRIMARY_API_KEY=sk-ant-...
# MODEL_BACKGROUND_API_KEY=sk-ant-...
# MODEL_FALLBACK_API_KEY=sk-...
# MODEL_BACKGROUND_FALLBACK_API_KEY=sk-...
# MODEL_EMBEDDING_API_KEY=sk-...

# ------------------------------------------------------------
# Model Selection
# Override these to swap models without changing code.
# ------------------------------------------------------------

# Conversation, home control, planning
MODEL_PRIMARY=claude-sonnet-4-5

# Background tasks: memory extraction, summarisation
MODEL_BACKGROUND=claude-haiku-4-5-20251001

# Fallback if primary provider is unavailable
MODEL_FALLBACK=gpt-4o

# Background fallback
MODEL_BACKGROUND_FALLBACK=gpt-4o-mini

# Embeddings (always OpenAI)
MODEL_EMBEDDING=text-embedding-3-small

# ------------------------------------------------------------
# Token Limits (per task type)
# ------------------------------------------------------------

MAX_TOKENS_CONVERSATION_INPUT=16000
MAX_TOKENS_CONVERSATION_OUTPUT=2048
MAX_TOKENS_HOME_CONTROL_INPUT=8000
MAX_TOKENS_HOME_CONTROL_OUTPUT=1024
MAX_TOKENS_PLANNING_INPUT=16000
MAX_TOKENS_PLANNING_OUTPUT=4096
MAX_TOKENS_BACKGROUND_INPUT=4000
MAX_TOKENS_BACKGROUND_OUTPUT=512

# ------------------------------------------------------------
# Feature Flags
# true | false
# ------------------------------------------------------------

# Use cheaper models (Haiku/Mini) for background tasks
FEATURE_CHEAP_BACKGROUND_MODELS=true

# Auto-fallback to secondary provider on API failure
FEATURE_FALLBACK_MODEL=true

# Require confirmation for high-impact home actions
FEATURE_POLICY_GATE=true

# Verify device state after write actions
FEATURE_ACTION_VERIFY=true

# WhatsApp channel (requires additional config below)
FEATURE_WHATSAPP=false

# Voice input via Whisper (not yet implemented)
FEATURE_VOICE=false

# Multi-home routing (not yet implemented)
FEATURE_MULTI_HOME=false

# Route background tasks to local Ollama model (not yet implemented)
FEATURE_LOCAL_MODEL=false

# Enable bash command execution tool (runs in sandboxed tools container)
# Requires TOOLS_MCP_URL to be set.
FEATURE_BASH=false

# Enable Python script execution tool (runs in sandboxed tools container)
# Requires TOOLS_MCP_URL to be set.
FEATURE_PYTHON=false

# Enable web page scraping tool (runs in sandboxed tools container)
# Requires TOOLS_MCP_URL to be set.
FEATURE_SCRAPE=false

# Enable web search tool (runs in sandboxed tools container, requires TAVILY_API_KEY)
# Requires TOOLS_MCP_URL to be set.
FEATURE_SEARCH=false

## Enable world model proposal generation (experimental)
FEATURE_WORLD_MODEL_PROPOSALS=true

## Enable multi-step task execution with state checkpoints (experimental)
FEATURE_MULTI_STEP_TASKS=true

# ------------------------------------------------------------
# Cloudflare Tunnel  (production only — exposes the webhook endpoint securely)
# See docs/integrations/cloudflare-tunnel.md for setup steps.
# ------------------------------------------------------------
# 1. Create a tunnel: https://one.dash.cloudflare.com → Zero Trust → Networks → Tunnels
# 2. Copy the tunnel token shown after creation
# 3. Under "Public Hostname" add:  your-domain.com  →  HTTP  http://homeagent:8080
# The token is the only secret — no credentials file or config mount needed.
CLOUDFLARE_TUNNEL_TOKEN=eyJhIjoichange-me...

# ------------------------------------------------------------
# Telegram
# ------------------------------------------------------------

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456789:ABC-...

# Webhook URL (public HTTPS URL pointing to this service)
# Leave empty to use polling in development mode.
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook/telegram

# Secret token for webhook validation (generate a random string)
TELEGRAM_WEBHOOK_SECRET=change-me-to-a-random-string

# Confirmation timeout in seconds (Policy Gate)
TELEGRAM_CONFIRM_TIMEOUT_SECONDS=60

# ------------------------------------------------------------
# Homey MCP  (local LAN — install "Homey AI Chat Control" app on your Homey)
# https://jvmenen.github.io/homey-ai-chat-control/
# No token or credentials required — LAN security only.
# ------------------------------------------------------------

# URL of the MCP server running on your Homey (replace with your Homey's LAN IP)
HOMEY_MCP_URL=http://192.168.1.x:3000/mcp

# How often to refresh the device snapshot cache (seconds)
HOMEY_POLL_INTERVAL_SECONDS=300

# How long to wait before verifying state after a write action (seconds)
HOMEY_VERIFY_DELAY_SECONDS=2

# ------------------------------------------------------------
# Prometheus MCP  (requires services/prometheus-mcp/ to be running)
# See services/prometheus-mcp/README.md for setup instructions.
# Enables tools: prom_query, prom_query_range, prom_list_metrics,
# prom_label_values, prom_series. Leave empty to disable.
# ------------------------------------------------------------

# URL of your Prometheus instance (used by services/prometheus-mcp/)
# PROMETHEUS_URL=http://192.168.1.x:9090

# URL of the Prometheus MCP server running on this machine (localhost if co-located)
# PROMETHEUS_MCP_URL=http://localhost:9000/mcp

# ------------------------------------------------------------
# Tools MCP  (services/tools-mcp/ — sandboxed execution tools)
# In Docker: tools container is referenced by service name.
# In dev:    run services/tools-mcp locally and use localhost.
# Leave empty to disable all execution tools.
# ------------------------------------------------------------

# URL of the Tools MCP server (set automatically in Docker via compose)
# TOOLS_MCP_URL=http://tools:9001/mcp       ← Docker (docker-compose)
# TOOLS_MCP_URL=http://localhost:9001/mcp   ← local dev

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------

# Environment: development | production | test
APP_ENV=development

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Log format: json (production) | console (development)
LOG_FORMAT=console

# Port the FastAPI server listens on (webhook endpoint — proxied by cloudflared)
PORT=8080

# Port for the admin dashboard (NOT routed via cloudflared)
ADMIN_PORT=9090

# Host for the admin dashboard inside the container. Defaults to 0.0.0.0 so
# Docker port forwarding works. LAN/internet access is restricted by the
# docker-compose port binding (127.0.0.1:9090:9090 on the host).
# Override to 127.0.0.1 only when running without Docker and you want loopback-only.
# ADMIN_HOST=0.0.0.0

# Secret key for internal API auth (generate a random string)
APP_SECRET_KEY=change-me-to-a-random-string

# Agent name shown to users (configurable per household preference)
AGENT_NAME=Home

# Household timezone — used for current time in agent context and scheduling
# Use IANA tz names: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
HOUSEHOLD_TIMEZONE=Europe/Oslo

# Directory containing editable prompt template files (relative to app root)
# Files: persona.md, instructions.md, home_context.md
# Loaded at startup. Send /reload (admin only) to hot-reload without restart.
PROMPTS_DIR=prompts

# ------------------------------------------------------------
# Rate Limiting
# Requests per user per minute. Disabled in development/test.
# ------------------------------------------------------------

RATE_LIMIT_PER_USER_PER_MINUTE=50

# ------------------------------------------------------------
# Alerting
# Minimum minutes between repeat admin alerts for the same event
# ------------------------------------------------------------

ALERT_COOLDOWN_MINUTES=30

# ------------------------------------------------------------
# Access Control
# The ONLY gate into the bot. Anyone not in ALLOWED_TELEGRAM_IDS
# is silently ignored — no response, no acknowledgement.
#
# How to find a Telegram user ID:
#   Open Telegram → message @userinfobot → it replies with your ID
#
# Format: comma-separated integers, no spaces
# ------------------------------------------------------------

# All Telegram user IDs permitted to use the bot
ALLOWED_TELEGRAM_IDS=111111111,222222222,333333333

# Subset of ALLOWED_TELEGRAM_IDS with admin privileges
# Must be a subset of ALLOWED_TELEGRAM_IDS
ADMIN_TELEGRAM_IDS=111111111

# ------------------------------------------------------------
# Data / Storage
# ------------------------------------------------------------

# Directory for SQLite database files (relative to app root)
DB_DIR=data/db

# Directory for Chroma vector store (relative to app root)
CHROMA_DIR=data/chroma

# Event log retention in days
EVENT_LOG_RETENTION_DAYS=90

# Agent run log retention in days
RUN_LOG_RETENTION_DAYS=90

# ------------------------------------------------------------
# Optional: Competing Action Detection
# ------------------------------------------------------------

# Window in seconds to check for recent actions on the same device
COMPETING_ACTION_WINDOW_SECONDS=60

# ------------------------------------------------------------
# Testing (development only — do not set in production)
# ------------------------------------------------------------

# ID of a safe, inconsequential Homey device to use in integration tests
# (e.g. a spare lamp that won't disturb anyone)
# HOMEY_TEST_DEVICE_ID=your-test-device-id

# Max LLM calls allowed per integration test run (cost guard)
# INTEGRATION_TEST_MAX_LLM_CALLS=10


# ------------------------------------------------------------
# Optional: WhatsApp (requires FEATURE_WHATSAPP=true)
# ------------------------------------------------------------

# WHATSAPP_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_NUMBER=

# ------------------------------------------------------------
# Optional: Local model via Ollama (requires FEATURE_LOCAL_MODEL=true)
# ------------------------------------------------------------

# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# ------------------------------------------------------------
# Tools MCP configuration (applies to services/tools-mcp/ container)
# These settings are read by the tools container, not homeagent.
# ------------------------------------------------------------

# Workspace root inside the tools container (mapped to ./data/workspace on host)
# WORKSPACE_DIR=/workspace

# Comma-separated allowlist of command names for the bash tool.
# Leave empty to use the built-in defaults (ls, cat, grep, find, git, etc.)
# BASH_ALLOWED_COMMANDS=ls,cat,grep,rg,find,head,tail,python3,git,date

# Maximum seconds a single bash command may run before being killed
# BASH_MAX_TIMEOUT_SECONDS=60

# Maximum output size in bytes (stdout and stderr each)
# BASH_MAX_OUTPUT_BYTES=200000

# Maximum seconds a Python script may run before being killed
# PYTHON_MAX_TIMEOUT_SECONDS=60

# Maximum output size in bytes for Python scripts
# PYTHON_MAX_OUTPUT_BYTES=200000

# Scrape request timeout in seconds
# SCRAPE_TIMEOUT_SECONDS=30

# Maximum content length returned to the agent (bytes)
# SCRAPE_MAX_CONTENT_BYTES=100000

# Search provider — currently only "tavily" is supported
# SEARCH_PROVIDER=tavily

# Tavily API key — sign up at https://tavily.com (free tier: 1000 searches/month)
# TAVILY_API_KEY=tvly-...

# Maximum number of search results per query
# SEARCH_MAX_RESULTS=5


## Skill related config

# ------------------------------------------------------------
# Optional: Vegvesen DATEX II  (vegvesen-datex skill)
# Credentials from Statens vegvesen — contact them to get access.
# https://www.vegvesen.no/fag/teknologi/nasjonal-vegdatabank/datex/
# ------------------------------------------------------------

# VEGVESEN_DATEX_USERNAME=your_username
# VEGVESEN_DATEX_PASSWORD=your_password

# Forward these credentials to skill scripts running in the tools container.
# Add any skill credential vars here (comma-separated).
# TOOLS_PASSTHROUGH_ENV=VEGVESEN_DATEX_USERNAME,VEGVESEN_DATEX_PASSWORD

# ------------------------------------------------------------
# Optional: Wine Cellar  (requires FEATURE_WINE=true)
#
# Enables read-only wine inventory tools backed by an Excel workbook
# in Microsoft 365. The workbook is downloaded via Microsoft Graph
# using app-only credentials (no delegated user required).
#
# Setup:
#   1. Register an Entra ID app in your Microsoft 365 tenant.
#   2. Grant it read access to the workbook or containing SharePoint site.
#      Preferred: Sites.Selected or Files.SelectedOperations.Selected
#      Acceptable: Sites.Read.All (avoid tenant-wide if possible)
#   3. Create a client secret and copy the values below.
#   4. Find WINE_GRAPH_ITEM_ID via Graph Explorer:
#      GET https://graph.microsoft.com/v1.0/drives/{drive-id}/root/children
#      The item ID is stable even if the file is renamed or moved.
# ------------------------------------------------------------

# Enable the wine cellar feature
# FEATURE_WINE=false

# --- Microsoft Graph credentials (required when FEATURE_WINE=true) ---

# Tenant (directory) ID from Entra ID app overview
# WINE_GRAPH_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Application (client) ID from Entra ID app overview
# WINE_GRAPH_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Client secret value (not the secret ID) — never commit this
# WINE_GRAPH_CLIENT_SECRET=your-client-secret

# OneDrive/SharePoint drive ID containing the workbook
# WINE_GRAPH_DRIVE_ID=b!xxxxxxxx...

# Stable item ID of the Excel workbook file
# WINE_GRAPH_ITEM_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Workbook structure (optional) ---

# Name of the Excel Table within the sheet (if data is a named Table object)
# Leave empty to scan the first worksheet for a header row instead
# WINE_EXCEL_TABLE_NAME=Vinkjeller

# Name of the worksheet to read (leave empty to use the first sheet)
# WINE_WORKSHEET_NAME=

# --- Sync and cache ---

# How long a cached snapshot is considered fresh before re-checking Graph (seconds)
# Default: 21600 (6 hours)
# WINE_CACHE_TTL_SECONDS=21600

# Cron schedule for the daily background refresh (household timezone)
# Default: every day at 06:00
# WINE_REFRESH_CRON=0 6 * * *

# --- Search behaviour ---

# Default number of candidates returned per search_wine_cellar call.
# The LLM may call the tool multiple times with different filters to find the
# best available bottle — a higher limit ensures good candidates aren't hidden.
# Default: 20
# WINE_SEARCH_DEFAULT_LIMIT=20

# ------------------------------------------------------------
# Optional: Flight Monitor  (requires FEATURE_FLIGHT_MONITOR=true)
#
# Enables persistent flight tracking with push alerts and polling fallback.
# V1 provider: AeroDataBox via RapidAPI (https://rapidapi.com/aerodatabox/api/aerodatabox)
#
# Setup:
#   1. Subscribe to AeroDataBox on RapidAPI.
#   2. Copy your RapidAPI key from the subscription page.
#   3. Set FLIGHT_WEBHOOK_PUBLIC_BASE_URL to your Cloudflare Tunnel public hostname.
#      The app constructs per-watch webhook URLs as:
#        {FLIGHT_WEBHOOK_PUBLIC_BASE_URL}/webhook/flights/{vendor}/{token}
#   4. Set FEATURE_FLIGHT_MONITOR=true to enable tools and webhooks.
# ------------------------------------------------------------

# Enable the flight monitor feature
# FEATURE_FLIGHT_MONITOR=false

# Flight data provider (currently only "aerodatabox" is supported)
# FLIGHT_PROVIDER=aerodatabox

# --- AeroDataBox / RapidAPI credentials ---

# Your RapidAPI key (from the subscription page — never commit this)
# FLIGHT_AERODATABOX_RAPIDAPI_KEY=your-rapidapi-key

# RapidAPI host header for AeroDataBox (verify from your subscription page)
# FLIGHT_AERODATABOX_RAPIDAPI_HOST=aerodatabox.p.rapidapi.com

# AeroDataBox base URL via RapidAPI
# FLIGHT_AERODATABOX_BASE_URL=https://aerodatabox.p.rapidapi.com

# Enable AeroDataBox push alert subscriptions (requires credits)
# FLIGHT_AERODATABOX_ALERTS_ENABLED=true

# Allow airport-level alert subscriptions (very noisy — keep false for household use)
# FLIGHT_AERODATABOX_ALLOW_AIRPORT_ALERTS=false

# --- Webhook ---

# Public base URL used when registering per-watch webhook URLs with the provider.
# Must be the public HTTPS hostname that routes to this service.
# Example: https://your-domain.com
# FLIGHT_WEBHOOK_PUBLIC_BASE_URL=https://your-domain.com

# --- Polling and monitoring behaviour ---

# Suppress the next poll when a webhook refreshed the same watch within this window (minutes)
# FLIGHT_POLL_RECENT_WEBHOOK_SUPPRESS_MINUTES=20

# Days before departure to start retrying deferred alert subscriptions (default: 7)
# FLIGHT_SUBSCRIPTION_RETRY_LEAD_DAYS=7

# Consecutive provider errors before a watch is marked FAILED (default: 5)
# FLIGHT_WATCH_FAIL_CONSECUTIVE_ERRORS=5

# Hours after scheduled arrival that monitoring remains active (default: 24)
# FLIGHT_MONITOR_ENDS_HOURS_AFTER_ARRIVAL=24

# --- Alert credit monitoring (AeroDataBox) ---

# Emit a low-credit warning when balance drops to or below this value (default: 25)
# FLIGHT_ALERT_MIN_CREDITS=25

# --- Retention ---

# Raw flight event rows are deleted after this many days (default: 60)
# FLIGHT_RAW_EVENT_RETENTION_DAYS=60

# Completed/cancelled/failed watch rows and snapshots deleted after this many days (default: 180)
# FLIGHT_COMPLETED_WATCH_RETENTION_DAYS=180

# =============================================================================
# Email channel via AgentMail  (requires FEATURE_EMAIL_CHANNEL=true)
# =============================================================================

# FEATURE_EMAIL_CHANNEL=false

# AgentMail API key
# AGENTMAIL_API_KEY=...

# AgentMail inbox address (the inbox_id is the email address)
# AGENTMAIL_INBOX_ID=agent@agentmail.to
# AGENTMAIL_ADDRESS=agent@agentmail.to

# Svix webhook endpoint id and signing secret
# AGENTMAIL_WEBHOOK_ID=ep_...
# AGENTMAIL_WEBHOOK_SECRET=whsec_...

# Public URL that AgentMail will POST webhook events to
# AGENTMAIL_WEBHOOK_PUBLIC_URL=https://<your-public-host>/webhook/agentmail

# --- Behaviour ---

# Silently drop emails from senders not mapped to a user (default: true)
# EMAIL_CHANNEL_REQUIRE_MAPPED_SENDER=true

# Send an ack reply email after the user confirms intake in Telegram (default: false)
# EMAIL_CHANNEL_ALLOW_REPLY_TO=false

# Save email-originated runs to conversation history (default: false)
# EMAIL_CHANNEL_SAVE_HISTORY=false

# Max characters of preprocessed email content passed to the agent
# EMAIL_CHANNEL_MAX_AGENT_CHARS=12000

# Reject webhook payloads larger than this (bytes, default: 1 MB)
# EMAIL_CHANNEL_MAX_RAW_BODY_BYTES=1048576

# Hours to look back when force-checking the inbox
# EMAIL_CHANNEL_LOOKBACK_HOURS=24

# Max messages to process per force-check call
# EMAIL_CHANNEL_FORCE_CHECK_LIMIT=10

# How long to keep EmailMessage rows (days)
# EMAIL_CHANNEL_RETENTION_DAYS=90
