# ============================================================
# Prometheus MCP Server — Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# ----------------------------------------------------------
# Prometheus backend
# ----------------------------------------------------------

# URL of your Prometheus instance (LAN IP preferred)
PROMETHEUS_URL=http://192.168.1.x:9090

# Optional Bearer token — leave empty for unauthenticated LAN access
# PROMETHEUS_BEARER_TOKEN=your-token

# ----------------------------------------------------------
# MCP server
# ----------------------------------------------------------

# Host and port the MCP server listens on.
# HomeAgent connects to http://<MCP_HOST>:<MCP_PORT>/mcp
MCP_HOST=0.0.0.0
MCP_PORT=9000

# ----------------------------------------------------------
# Guardrails (numeric limits — tune for your setup)
# ----------------------------------------------------------

# Timeout for Prometheus API requests (seconds)
PROM_TIMEOUT_SECONDS=10

# Maximum time range for prom_query_range (hours)
PROM_MAX_RANGE_HOURS=24

# Minimum resolution step for prom_query_range (seconds)
# 60 = 1-minute resolution; raise to 300 for lighter load
PROM_MIN_STEP_SECONDS=60

# Maximum number of series returned by a single query
PROM_MAX_SERIES=50

# Maximum total datapoints across all series (checked before the query)
PROM_MAX_DATAPOINTS=10000

# Maximum Prometheus response body size in bytes
PROM_MAX_RESPONSE_BYTES=2000000

# Optional comma-separated metric name prefix allowlist.
# Empty = allow all queries. Example: "node_,process_,up"
# PROM_METRIC_PREFIX_ALLOWLIST=node_,process_
